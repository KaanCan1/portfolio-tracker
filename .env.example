# ─── Veri sağlayıcı anahtarları (ücretsiz) ───────────────────────────────
# Finnhub: fiyat + bilanço + analist + insider — https://finnhub.io/register
FINNHUB_API_KEY=
# Twelve Data: günlük mum (RSI/SMA/ATR → Radar + Swing) — https://twelvedata.com
TWELVEDATA_API_KEY=
# Tiingo (opsiyonel) — https://www.tiingo.com
TIINGO_API_KEY=

# ─── Kalıcı depolama ─────────────────────────────────────────────────────
# Render free diskte veri kaybını önler. Supabase "Session pooler" bağlantı
# dizesini kullan (IPv4 + tam uyumlu). Tanımsızsa yerel portfolio.json kullanılır.
# Render'da da aynı değişkeni Environment olarak ekle.
DATABASE_URL=

# ─── Giriş / oturum ──────────────────────────────────────────────────────
# Pano şifresi + oturum imza gizi (Render → Environment'a da ekle)
AUTH_PASSWORD=
AUTH_SECRET=

# ─── E-posta uyarıları (Portföy Bekçisi + haftalık Alfa Avı) — opsiyonel ──
RESEND_API_KEY=

# ─── Claude AI (Tez Masası + gün denetimi) — opsiyonel ───────────────────
# https://platform.claude.com → API key. Tanımsızsa AI panelleri kendini gizler.
ANTHROPIC_API_KEY=
# Varsayılan model: claude-opus-4-8 (istersen değiştir)
AI_MODEL=

# ─── MCP sunucusu (scripts/mcp-portfoy.js) — Claude Code/Desktop için ────
# PORTFOY_URL=https://<uygulaman>.onrender.com
# PORTFOY_PASSWORD=<pano şifren>
